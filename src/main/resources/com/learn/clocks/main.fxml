<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.learn.clocks.Controller"
            stylesheets="@style.css">

  <top>
    <VBox spacing="8" styleClass="top-panel">
      <Label fx:id="centralTimeLabel" text="Центральное время: 0 сек" styleClass="central-time" />
      <HBox spacing="8">
        <Button text="▶ Старт" onAction="#startCentral" />
        <Button text="⏸ Стоп" onAction="#stopCentral" />
        <TextField fx:id="setTimeField" promptText="Установить время" />
        <Button text="Применить" onAction="#applyTime" />
      </HBox>
    </VBox>
  </top>

  <center>
    <ScrollPane fitToWidth="true">
      <VBox fx:id="devicesBox" spacing="12" />
    </ScrollPane>
  </center>

  <bottom>
    <ToolBar>
      <Button text="Добавить секундомер" onAction="#addStopwatch" />
      <Button text="Добавить таймер" onAction="#addTimer" />
      <Button text="Добавить будильник" onAction="#addAlarm" />
    </ToolBar>
  </bottom>

</BorderPane>